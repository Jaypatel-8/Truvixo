    "autoprefixer": "^10.4.0",
    "lucide-react": "^0.300.0",
    "next": "^14.0.4",
    "nodemailer": "^8.0.4",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
